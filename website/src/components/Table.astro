---
interface Props {
  headers: string[];
  rows: string[][];
}

const { headers, rows } = Astro.props;
---

<table>
  <thead>
    <tr>{headers.map((h) => <th set:html={h} />)}</tr>
  </thead>
  <tbody>
    {
      rows.map((row) => (
        <tr>
          {row.map((cell) => (
            <td set:html={cell} />
          ))}
        </tr>
      ))
    }
  </tbody>
</table>
