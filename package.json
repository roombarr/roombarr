    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@nestjs/testing": "^11.0.1",
    "@types/bun": "^1.2.4",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "supertest": "^7.0.0",
    "typescript": "^5.7.3"
  }
